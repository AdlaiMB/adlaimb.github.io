---
import '../styles/global.css';
const { pageTitle } = Astro.props;
---

<!-- TODO: why is it type="svg+xml"? -->

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/Personal-Website/logo.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
	</head>
	<body>
        <slot/>
	</body>
</html>

<style>
	body {
		margin: 0;
	}
</style>